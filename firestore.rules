rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function erInnlogget() {
      return request.auth != null;
    }
    function erEier(uid) {
      return erInnlogget() && request.auth.uid == uid;
    }
    function erAdmin() {
      return erInnlogget()
        && exists(/databases/$(database)/documents/brukere/$(request.auth.uid))
        && get(/databases/$(database)/documents/brukere/$(request.auth.uid)).data.rolle == 'admin';
    }
    function erFrosset() {
      return erInnlogget()
        && exists(/databases/$(database)/documents/brukere/$(request.auth.uid))
        && get(/databases/$(database)/documents/brukere/$(request.auth.uid)).data.get('frosset', false) == true;
    }
    // Tipping på en kamp låses i det kampen starter (avspark).
    function kampAapen(matchId) {
      return exists(/databases/$(database)/documents/kamper/$(matchId))
        && get(/databases/$(database)/documents/kamper/$(matchId)).data.starttid > request.time.toMillis();
    }

    // Spesialtips låses når første VM-kamp starter (avspark 11. juni 2026 = 21:00 norsk tid).
    // Konstanten = new Date('2026-06-11T15:00:00-04:00').getTime() = 1781204400000
    function spesialAapen() {
      return request.time.toMillis() < 1781204400000;
    }

    // Admin kan midlertidig åpne spesialtips for én bruker via feltet
    // spesialAapenTil (epoch-ms) på brukerdoc-en. Gjelder så lenge tiden > nå.
    function spesialAapenForBruker(uid) {
      return exists(/databases/$(database)/documents/brukere/$(uid))
        && get(/databases/$(database)/documents/brukere/$(uid)).data.get('spesialAapenTil', 0) > request.time.toMillis();
    }

    // Brukere: alle innloggede kan lese (ledertavle).
    // Eier kan opprette egen profil med medlems-rolle og 0 poeng.
    // Eier kan oppdatere navn/avdeling, men ikke rolle eller poeng.
    // Admin kan alt.
    match /brukere/{uid} {
      allow read: if erInnlogget();
      allow create: if erEier(uid)
        && request.resource.data.rolle == 'medlem'
        && request.resource.data.poeng == 0;
      allow update: if (erEier(uid)
        && request.resource.data.rolle == resource.data.rolle
        && request.resource.data.poeng == resource.data.poeng
        && request.resource.data.get('spesialAapenTil', 0) == resource.data.get('spesialAapenTil', 0))
        || erAdmin();
      allow delete: if erAdmin();
    }

    // Kamper: alle innloggede kan lese, bare admin skriver.
    match /kamper/{matchId} {
      allow read: if erInnlogget();
      allow write: if erAdmin();
    }

    // Tips: alle innloggede kan lese, eier kan opprette/oppdatere/slette
    // egne tipps frem til kampstart. Frosne brukere kan ikke skrive.
    match /tips/{tipId} {
      allow read: if erInnlogget();
      allow create: if erInnlogget()
        && !erFrosset()
        && request.resource.data.uid == request.auth.uid
        && kampAapen(request.resource.data.matchId);
      allow update: if !erFrosset()
        && resource.data.uid == request.auth.uid
        && kampAapen(resource.data.matchId);
      allow delete: if (!erFrosset()
        && resource.data.uid == request.auth.uid
        && kampAapen(resource.data.matchId))
        || erAdmin();
    }

    // Spesialtips: alle kan lese (for ledertavle), eier skriver egen
    // frem til første VM-kamp starter (avspark). Frosne brukere kan ikke skrive.
    match /spesialtips/{uid} {
      allow read: if erInnlogget();
      allow create, update: if erEier(uid) && !erFrosset()
        && (spesialAapen() || spesialAapenForBruker(uid));
      allow delete: if (erEier(uid) && !erFrosset()
        && (spesialAapen() || spesialAapenForBruker(uid))) || erAdmin();
    }

    // Fasit: alle kan lese, bare admin skriver.
    match /fasit/{dok} {
      allow read: if erInnlogget();
      allow write: if erAdmin();
    }

    // Aggregert ledertavle: alle kan lese. Skrives av GitHub Actions (service
    // account omgår rules) ELLER av admin via "Synk nå"-knappen i appen.
    match /aggregert/{dok} {
      allow read: if erInnlogget();
      allow write: if erAdmin();
    }
  }
}
